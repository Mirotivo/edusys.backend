{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Sqlite": "Filename=./Database/skillseekdb.sqlite"
  },
  "Skillseek": {
    "App": {
      "Name": "%Skillseek__App__Name%",
      "BaseUrl": "%Skillseek__App__BaseUrl%",
      "FrontEndUrl": "%Skillseek__App__FrontendUrl%",
      "SupportEmail": "%Skillseek__App__SupportEmail%",
      "SupportPhone": "%Skillseek__App__SupportPhone%"
    },
    "Jwt": {
      "Key": "%Skillseek__Jwt__Key%",
      "Issuer": "YourIssuer",
      "Audience": "YourAudience",
      "ExpiryDays": 7    
    },
    "Payments": {
      "Stripe": {
        "ApiKey": "%Skillseek__Payments__Stripe__ApiKey%",
        "SecretKey": "%Skillseek__Payments__Stripe__SecretKey%",
        "PublishableKey": "%Skillseek__Payments__Stripe__PublishableKey%"
      },
      "PayPal": {
        "Environment": "%Skillseek__Payments__Paypal__Environment%",
        "ClientId": "%Skillseek__Payments__Paypal__ClientId%",
        "ClientSecret": "%Skillseek__Payments__Paypal__ClientSecret%"
      }
    },
    "Notifications": {
      "SendGrid": {
        "ApiKey": "%Skillseek__Notifications__Sendgrid__ApiKey%",
        "FromEmail": "%Skillseek__Notifications__Sendgrid__FromEmail%",
        "FromName": "%Skillseek__Notifications__Sendgrid__FromName%"
      },
      "Twilio": {
        "AccountSid": "%Skillseek__Notifications__Twilio__AccountSid%",
        "AuthToken": "%Skillseek__Notifications__Twilio__AuthToken%",
        "FromPhoneNumber": "%Skillseek__Notifications__Twilio__FromPhoneNumber%"
      }
    },
    "ExternalServices": {
      "Google": {
        "ApiKey": "%Skillseek__ExternalServices__Google__ApiKey%",
        "ClientId": "%Skillseek__ExternalServices__Google__ClientId%",
        "ClientSecret": "%Skillseek__ExternalServices__Google__ClientSecret%"
      },
      "Facebook": {
        "AppId": "%Skillseek__ExternalServices__Facebook__AppId%",
        "AppSecret": "%Skillseek__ExternalServices__Facebook__AppSecret%"
      }
    }
  }
}